# LLM API 配置（用于 AI 修正转录）
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-chat

# HuggingFace Token（用于 pyannote 说话人区分）
# 需在 https://huggingface.co/pyannote/speaker-diarization-3.1 同意条款
HF_TOKEN=your_hf_token_here

# 中文字体路径（PDF 导出用，默认系统字体）
# PDF_FONT_PATH=/usr/share/fonts/NotoSansCJK-Regular.ttc
